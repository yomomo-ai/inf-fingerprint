# inf-fingerprint server config — copy to config.toml and fill in your values.

[database]
host = "127.0.0.1"
port = 5432
user = "fingerprint"
password = "change-me"
db_name = "fingerprint"
schema = "fingerprint"

[database.pool]
max_conns = 16
min_conns = 4
max_conn_lifetime = "1h"
max_conn_idle_time = "5m"
acquire_timeout = "5s"
statement_timeout = "5s"

[server]
bind = "0.0.0.0:28091"

[matcher]
match_threshold = 12.0
ambiguous_threshold = 6.0
max_candidates = 200

[matcher.bucket_cache]
# In-memory cache of bucket → candidate signatures. Hot buckets (popular
# iPhone+WeChat combos) hit this 99%+ of the time and skip the DB read path.
capacity = 10000
ttl = "60s"
